############################################
# Environment Selector
############################################
# Set to DEV, TEST, or PROD — all environment-specific keys below
# are prefixed accordingly. The app reads ${APP_ENV}_KEY → KEY.
APP_ENV=DEV

############################################
# Global (same across all environments)
############################################
APP_NAME=NeuraLeads AI Agent
LOG_LEVEL=INFO
TIMEZONE=America/Chicago

# Data Storage
DATA_STORAGE=database

# Business Rules
DAILY_SEND_LIMIT=30
COOLDOWN_DAYS=10
MAX_CONTACTS_PER_COMPANY_PER_JOB=4
MIN_SALARY_THRESHOLD=30000
DATA_RETENTION_DAYS=180

# Email Sending Mode
EMAIL_SEND_MODE=mailmerge

# Provider Selection (mock for dev/test, real for prod)
CONTACT_PROVIDER=mock
EMAIL_VALIDATION_PROVIDER=mock

############################################
# TEST
############################################
TEST_DB_TYPE=sqlite
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_NAME=
TEST_DB_USER=
TEST_DB_PASSWORD=
TEST_SECRET_KEY=test-secret-key-not-for-production
TEST_ENCRYPTION_KEY=
TEST_REDIS_URL=redis://localhost:6379/1
TEST_DEBUG=true
TEST_HOST=127.0.0.1
TEST_PORT=8000
TEST_BASE_URL=http://localhost:8000
TEST_CORS_ORIGINS=http://localhost:3000

############################################
# DEV
############################################
DEV_DB_TYPE=mysql
DEV_DB_HOST=localhost
DEV_DB_PORT=3306
DEV_DB_NAME=exzelon_ra_agent
DEV_DB_USER=ra_user
DEV_DB_PASSWORD=
DEV_SECRET_KEY=
DEV_ENCRYPTION_KEY=
DEV_REDIS_URL=redis://localhost:6379/0
DEV_DEBUG=true
DEV_HOST=127.0.0.1
DEV_PORT=8000
DEV_BASE_URL=http://localhost:8000
DEV_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# API Keys (dev)
DEV_JSEARCH_API_KEY=
DEV_APOLLO_API_KEY=
DEV_SEAMLESS_API_KEY=
DEV_NEVERBOUNCE_API_KEY=
DEV_ZEROBOUNCE_API_KEY=
DEV_HUNTER_API_KEY=
DEV_CLEAROUT_API_KEY=

# SMTP (dev)
DEV_SMTP_HOST=
DEV_SMTP_PORT=587
DEV_SMTP_USER=
DEV_SMTP_PASSWORD=

# Admin seeding (dev)
DEV_ADMIN_EMAIL=admin@exzelon.com
DEV_ADMIN_PASSWORD=

# Optional OS-specific paths
# DEV_EXPORT_PATH_WIN=C:\path\to\exports
# DEV_EXPORT_PATH_LINUX=/var/data/exports

############################################
# PROD
############################################
PROD_DB_TYPE=mysql
PROD_DB_HOST=
PROD_DB_PORT=3306
PROD_DB_NAME=exzelon_ra_agent
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_SECRET_KEY=
PROD_ENCRYPTION_KEY=
PROD_REDIS_URL=redis://localhost:6379/0
PROD_DEBUG=false
PROD_HOST=0.0.0.0
PROD_PORT=8000
PROD_BASE_URL=https://yourdomain.com
PROD_CORS_ORIGINS=https://yourdomain.com

# API Keys (prod)
PROD_JSEARCH_API_KEY=
PROD_APOLLO_API_KEY=
PROD_SEAMLESS_API_KEY=

# SMTP (prod)
PROD_SMTP_HOST=
PROD_SMTP_PORT=587
PROD_SMTP_USER=
PROD_SMTP_PASSWORD=

# Admin seeding (prod)
PROD_ADMIN_EMAIL=admin@exzelon.com
PROD_ADMIN_PASSWORD=

# Docker-specific (used by docker-compose)
DB_ROOT_PASSWORD=
