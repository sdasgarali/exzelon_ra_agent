[Unit]
Description=NeuraLeads AI Agent — FastAPI Backend (uvicorn)
After=network.target mysql.service redis-server.service
Wants=mysql.service redis-server.service

[Service]
Type=simple
User=ra-user
Group=ra-user
WorkingDirectory=/opt/exzelon-ra-agent/backend
Environment="PATH=/opt/exzelon-ra-agent/backend/venv/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/opt/exzelon-ra-agent/backend/.env
ExecStart=/opt/exzelon-ra-agent/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4 --log-level info
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=exzelon-api

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
